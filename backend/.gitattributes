# Default behavior
* text=auto

# Shell scripts must use LF
*.sh text eol=lf
mvnw text eol=lf

# Windows scripts must use CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Source files
*.java text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.scss text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf